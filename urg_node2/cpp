#ifndef URG_NODE2_URG_NODE2_HPP_
#define URG_NODE2_URG_NODE2_HPP_

#include <string>
#include <thread>
#include <vector>

#include "rclcpp/rclcpp.hpp"
#include "sensor_msgs/msg/laser_scan.hpp"
#include "urg_sensor.h"

class UrgScanNode : public rclcpp::Node
{
public:
  UrgScanNode();
  ~UrgScanNode() override;

private:
  bool connect_lidar();
  void disconnect_lidar();
  void scan_loop();
  bool make_scan_message(sensor_msgs::msg::LaserScan & msg);

  rclcpp::Publisher<sensor_msgs::msg::LaserScan>::SharedPtr scan_pub_;
  std::thread scan_thread_;
  bool stop_thread_ = false;

  urg_t urg_;
  bool connected_ = false;
  std::vector<long> distance_;

  std::string serial_port_;
  int serial_baud_;
  std::string frame_id_;

  double scan_period_ = 0.0;
  double angle_min_ = 0.0;
  double angle_max_ = 0.0;
  double angle_increment_ = 0.0;
  double time_increment_ = 0.0;
  double range_min_ = 0.0;
  double range_max_ = 0.0;
};

#endif  // URG_NODE2_URG_NODE2_HPP_
